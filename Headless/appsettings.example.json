{
  "Urls": "http://localhost:5155",
  "Monitor": {
    "StoragePath": "data\\headless\\performance-monitor.duckdb",
    "ArchiveDirectory": "data\\headless\\parquet",
    "CollectionIntervalSeconds": 60,
    "MaxConcurrentServers": 8,
    "CommandTimeoutSeconds": 30,
    "ArchiveIntervalMinutes": 60,
    "HotDataDays": 7,
    "Collectors": [
      {
        "Name": "server_properties",
        "Enabled": true,
        "FrequencySeconds": 3600
      },
      {
        "Name": "wait_stats",
        "Enabled": true,
        "FrequencySeconds": 60
      },
      {
        "Name": "cpu_utilization",
        "Enabled": true,
        "FrequencySeconds": 60
      }
    ],
    "Servers": [
      {
        "Id": "sample-dev",
        "DisplayName": "Sample Dev SQL",
        "ConnectionStringEnvironmentVariable": "PM_SAMPLE_DEV_CONNECTION",
        "Enabled": false
      }
    ]
  }
}
